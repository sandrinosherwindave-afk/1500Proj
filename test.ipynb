    "import tkinter as tk\n",
    "\n",
    "root = tk.Tk()\n",
    "btn = tk.Button(root, \n",
    "                text=\"Click Me\", \n",
    "                bg=\"lightgray\", \n",
    "                activebackground=\"blue\", \n",
    "                activeforeground=\"white\",\n",
    "                relief=\"raised\")\n",
    "btn.pack(pady=20)\n",
    "root.mainloop()"
   ]
  }
